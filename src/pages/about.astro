---
import Base from '../layouts/Base.astro';
import Slideshow from '../components/Slideshow.astro';
import resume from '../data/resume.json';
import { withBase } from '../lib/url';

const designSkills =
  resume.skills.find((g) => g.group === 'Design & Manufacturing')?.items.slice(0, 6) ?? [];
const embeddedSkills = resume.skills.find((g) => g.group === 'Embedded')?.items.slice(0, 5) ?? [];

// Photos for the top slideshow. Images live in public/images/about/.
const slides = [
  { image: '/images/about/surfing.jpg', caption: 'Surfing near Santa Cruz', alt: 'Surfing near Santa Cruz' },
  { image: '/images/about/guitar-fire.jpg', caption: 'Camping, fire, guitar', alt: 'Playing guitar with a friend around a campfire' },
  { image: '/images/about/guitar-stage.jpg', caption: '2021 Memphis International Blues Festival', alt: 'Bastola Band Gig' },
  { image: '/images/about/welding-arc.jpg', caption: 'Weekend hull repair outside the home shop.', alt: 'Welding an aluminum hull outdoors' },
  { image: '/images/about/oxy-cutting.jpg', caption: 'Oxy-fuel work at the shop in Maryland.', alt: 'Oxy Cutting' },
  { image: '/images/about/jcm-fab.jpg', caption: 'A finished fab job from my time at JCM Associates.', alt: 'Welding' },
];
---

<Base
  title="About"
  description="More about Jesse Kegley: robotics engineering, fabrication, embedded systems, and the hands-on path between them."
>
  <section class="about-hero dot-grid">
    <div class="container">
      <p class="kicker">About</p>
      <h1>Engineering, welding, guitar and surfing.</h1>
      <div class="hero-grid">
        <Slideshow slides={slides} />
        <div class="intro">
          <p>
            Outside of coursework and personal or work projects, I'm usually out in the water north of Santa Cruz surfing.
            It's a hobby that I naturally picked up a couple years before coming to school, having come from a family of swimmers, 
            and living on the Santa Cruz coast has only deepened my appreciation for any time I get to spend out in the water.
            
          </p>
          <p>
            I also love playing the guitar, which I picked up in middle school, joining an R&B band in high school with my buddies 
            which we kept going until graduation. We catch up when I'm back home, where I generally spend my time boating with my 
            family, fixing up equipment, and catching up on jobs.
          </p>
          <div class="hero-actions">
            <a class="btn" href={withBase('/projects/')}>Projects</a>
            <a class="btn btn-ghost" href={withBase('/fabrication/')}>Fabrication</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section">
    <div class="container story-grid">


        <p>
        </p>
      </div>
    </div>
  </section>




</Base>

<style>
  .about-hero {
    padding-block: clamp(4rem, 10vw, 7rem) clamp(3rem, 7vw, 4.5rem);
  }

  h1 {
    font-size: clamp(2.3rem, 6vw, 4rem);
    max-width: 20ch;
    margin-bottom: clamp(1.6rem, 4vw, 2.4rem);
  }

  h2 {
    font-size: clamp(1.5rem, 3vw, 2rem);
    margin-bottom: 0.9rem;
  }

  .hero-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.35fr) minmax(260px, 0.75fr);
    gap: clamp(2rem, 6vw, 4rem);
    align-items: start;
  }

  .intro {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--ink-soft);
    max-width: 52ch;
    font-size: 1.02rem;
  }

  .hero-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.8rem;
    margin-top: 0.6rem;
  }

  .story-grid,
  .skill-split {
    display: grid;
    grid-template-columns: minmax(220px, 0.7fr) minmax(0, 1.3fr);
    gap: clamp(2rem, 6vw, 4rem);
    align-items: start;
  }

  .story-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    color: var(--ink-soft);
    max-width: 70ch;
  }

  .values-grid {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.5rem;
  }

  .values-grid article {
    border-top: 1px solid var(--line);
    padding-top: 1.4rem;
  }

  .values-grid p {
    color: var(--ink-soft);
  }

  .skill-columns {
    display: grid;
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: 1.4rem;
  }

  .skill-label {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-faint);
    margin-bottom: 0.6rem;
  }

  .skill-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
  }

  .skill-tags .tag {
    white-space: normal;
  }

  @media (max-width: 800px) {
    .hero-grid,
    .story-grid,
    .skill-split,
    .values-grid,
    .skill-columns {
      grid-template-columns: 1fr;
    }
  }
</style>
