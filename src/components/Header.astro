---
import site from '../data/site.json';
import { withBase } from '../lib/url';

const links = [
  { href: '/projects/', label: 'Projects' },
  { href: '/fabrication/', label: 'Fabrication' },
  { href: '/about/', label: 'About' },
  { href: '/resume/', label: 'Résumé' },
];

const path = Astro.url.pathname;
// Astro.url.pathname includes the base path, so compare against the based href.
const isActive = (href: string) => {
  const h = withBase(href);
  return path === h || path.startsWith(h);
};
---

<header class="site-header">
  <div class="container header-row">
    <a class="brand" href={withBase('/')}>
      <span class="brand-mark">JK</span>
      <span class="brand-name">{site.name}</span>
    </a>
    <nav aria-label="Main">
      {
        links.map((l) => (
          <a href={withBase(l.href)} class:list={['nav-link', { active: isActive(l.href) }]}>
            {l.label}
          </a>
        ))
      }
    </nav>
    <div class="header-actions">
      <a class="btn btn-contact" href={`mailto:${site.email}`}>Contact</a>
      <button
        class="theme-toggle"
        data-theme-toggle
        aria-label="Toggle color theme"
        title="Toggle color theme"
      >
        <svg
          class="icon-sun"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
        >
          <circle cx="12" cy="12" r="4"></circle>
          <path
            d="M12 2v2m0 16v2M4.9 4.9l1.4 1.4m11.4 11.4 1.4 1.4M2 12h2m16 0h2M4.9 19.1l1.4-1.4M17.7 6.3l1.4-1.4"
          ></path>
        </svg>
        <svg
          class="icon-moon"
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"></path>
        </svg>
      </button>
    </div>
  </div>
</header>

<script>
  document.querySelectorAll('[data-theme-toggle]').forEach((btn) => {
    btn.addEventListener('click', () => {
      const next = document.documentElement.dataset.theme === 'dark' ? 'light' : 'dark';
      document.documentElement.dataset.theme = next;
      localStorage.setItem('theme', next);
    });
  });
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 82%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--line);
  }

  .header-row {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    height: 60px;
  }

  .brand {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-right: auto;
  }

  .brand-mark {
    font-family: var(--font-mono);
    font-weight: 700;
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    background: var(--accent);
    color: var(--accent-contrast);
    padding: 0.28rem 0.45rem;
    border-radius: 4px;
  }

  .brand-name {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 1rem;
  }

  nav {
    display: flex;
    gap: 1.4rem;
  }

  .nav-link {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-soft);
    padding: 0.3rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.15s ease;
  }

  .nav-link:hover {
    color: var(--ink);
  }

  .nav-link.active {
    color: var(--ink);
    border-bottom-color: var(--accent);
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: 0.7rem;
  }

  .btn-contact {
    font-size: 0.85rem;
    padding: 0.42rem 0.9rem;
  }

  .theme-toggle {
    display: grid;
    place-items: center;
    width: 32px;
    height: 32px;
    border: 1px solid var(--line);
    border-radius: var(--radius);
    background: transparent;
    color: var(--ink-soft);
    cursor: pointer;
    transition: color 0.15s ease, border-color 0.15s ease;
  }

  .theme-toggle:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  .icon-moon {
    display: none;
  }

  :global([data-theme='dark']) .icon-moon {
    display: block;
  }

  :global([data-theme='dark']) .icon-sun {
    display: none;
  }

  @media (max-width: 640px) {
    .header-row {
      gap: 0.7rem;
      padding-inline: 0.8rem;
    }

    .brand-name {
      display: none;
    }

    .btn-contact {
      display: none;
    }

    nav {
      gap: 0.7rem;
    }

    .nav-link {
      font-size: 0.82rem;
    }
  }

  @media (max-width: 380px) {
    .brand {
      display: none;
    }

    nav {
      margin-right: auto;
    }
  }
</style>
