---
interface Props {
  kicker: string;
  title: string;
  moreHref?: string;
  moreLabel?: string;
}

const { kicker, title, moreHref, moreLabel = 'View all' } = Astro.props;
---

<div class="section-heading">
  <div>
    <p class="kicker">{kicker}</p>
    <h2>{title}</h2>
  </div>
  {
    moreHref && (
      <a class="more" href={moreHref}>
        {moreLabel} <span aria-hidden="true">→</span>
      </a>
    )
  }
</div>

<style>
  .section-heading {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2.2rem;
  }

  h2 {
    font-size: clamp(1.5rem, 3.5vw, 2rem);
  }

  .more {
    font-family: var(--font-display);
    font-size: 0.92rem;
    font-weight: 500;
    color: var(--ink-soft);
    white-space: nowrap;
    padding-bottom: 0.25rem;
  }

  .more:hover {
    color: var(--accent);
  }
</style>
